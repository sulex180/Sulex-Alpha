//@version=5
indicator("Sulex Alpha v0.2", overlay=true)

// ===== INPUTS =====
fastLength = input.int(20, "Fast EMA")
slowLength = input.int(50, "Slow EMA")
swingLength = input.int(5, "Swing Length", minval=2)

// ===== EMA =====
fastEMA = ta.ema(close, fastLength)
slowEMA = ta.ema(close, slowLength)

plot(fastEMA, color=color.green, linewidth=2, title="Fast EMA")
plot(slowEMA, color=color.red, linewidth=2, title="Slow EMA")

// ===== TREND =====
bullTrend = fastEMA > slowEMA
bearTrend = fastEMA < slowEMA

bgcolor(bullTrend ? color.new(color.green, 90) : bearTrend ? color.new(color.red, 90) : na)

// ===== SWING POINTS =====
pivotHigh = ta.pivothigh(high, swingLength, swingLength)
pivotLow = ta.pivotlow(low, swingLength, swingLength)

plotshape(pivotHigh, title="Swing High", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.tiny, offset=-swingLength)

plotshape(pivotLow, title="Swing Low", style=shape.triangleup, location=location.belowbar, color=color.lime, size=size.tiny, offset=-swingLength)

// ===== STORE LAST SWINGS =====
var float lastHigh = na
var float lastLow = na

if not na(pivotHigh)
    lastHigh := pivotHigh

if not na(pivotLow)
    lastLow := pivotLow

// ===== BOS =====
bullBOS = not na(lastHigh) and ta.crossover(close, lastHigh)
bearBOS = not na(lastLow) and ta.crossunder(close, lastLow)

plotshape(bullBOS, title="Bull BOS", text="BOS", style=shape.labelup, location=location.belowbar, color=color.green, textcolor=color.white)

plotshape(bearBOS, title="Bear BOS", text="BOS", style=shape.labeldown, location=location.abovebar, color=color.red, textcolor=color.white)

// ===== ALERTS =====
alertcondition(bullBOS, title="Bullish BOS", message="Bullish Break of Structure")
alertcondition(bearBOS, title="Bearish BOS", message="Bearish Break of Structure")
